# 公司云主机环境变量（Ubuntu x86_64 + 本地 Ollama）
#
# 使用方式: cp .env.cloud .env
# .env 不在 git 中，每个环境独立维护

COMPOSE_PROJECT_NAME=wrenai
PLATFORM=linux/amd64

PROJECT_DIR=.

# service port
WREN_ENGINE_PORT=8080
WREN_ENGINE_SQL_PORT=7432
WREN_AI_SERVICE_PORT=5555
WREN_UI_PORT=3000
IBIS_SERVER_PORT=8000
WREN_UI_ENDPOINT=http://wren-ui:${WREN_UI_PORT}

# ai service settings
QDRANT_HOST=qdrant
SHOULD_FORCE_DEPLOY=1

# LLM API Key — 本地 Ollama 不需要真实 key，填占位符即可
OPENAI_API_KEY=sk-local-placeholder

# version
WREN_PRODUCT_VERSION=0.29.1
WREN_ENGINE_VERSION=0.22.0
WREN_AI_SERVICE_VERSION=0.29.0
IBIS_SERVER_VERSION=0.22.0
WREN_UI_VERSION=0.32.2
WREN_BOOTSTRAP_VERSION=0.1.5

# user id
USER_UUID=7378aa8b-d1eb-4adb-8b33-f5fbd0b7be84

# telemetry — 公司环境关闭
POSTHOG_API_KEY=
POSTHOG_HOST=
TELEMETRY_ENABLED=false

GENERATION_MODEL=qwen3:32b
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=

# exposed ports
HOST_PORT=3000
AI_SERVICE_FORWARD_PORT=5555

EXPERIMENTAL_ENGINE_RUST_VERSION=false
LOCAL_STORAGE=.

# [自定义] 推荐问题开关 — 本地大模型慢，关闭
ENABLE_RECOMMENDATION_QUESTIONS=false

# chart-engine — 图表生成引擎
CHART_ENGINE_PORT=8100
CHART_LLM_MODEL=ollama_chat/qwen3:32b
CHART_LLM_API_BASE=http://10.220.239.55:11343
