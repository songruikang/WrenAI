COMPOSE_PROJECT_NAME=wrenai
PLATFORM=linux/arm64

PROJECT_DIR=.

# service port
WREN_ENGINE_PORT=8080
WREN_ENGINE_SQL_PORT=7432
WREN_AI_SERVICE_PORT=5555
WREN_UI_PORT=3000
IBIS_SERVER_PORT=8000
WREN_UI_ENDPOINT=http://wren-ui:${WREN_UI_PORT}

# ai service settings
QDRANT_HOST=qdrant
SHOULD_FORCE_DEPLOY=1

# vendor keys (using Ollama locally, no API key needed)
OPENAI_API_KEY=sk-d655daeffe97486d82c4a7ae345b792b
DEEPSEEK_API_KEY=sk-d655daeffe97486d82c4a7ae345b792b

# version
WREN_PRODUCT_VERSION=0.29.1
WREN_ENGINE_VERSION=0.22.0
WREN_AI_SERVICE_VERSION=0.29.0
IBIS_SERVER_VERSION=0.22.0
WREN_UI_VERSION=0.32.2
WREN_BOOTSTRAP_VERSION=0.1.5

# user id
USER_UUID=7378aa8b-d1eb-4adb-8b33-f5fbd0b7be84

# telemetry
POSTHOG_API_KEY=phc_nhF32aj4xHXOZb0oqr2cn4Oy9uiWzz6CCP4KZmRq9aE
POSTHOG_HOST=https://app.posthog.com
TELEMETRY_ENABLED=false

GENERATION_MODEL=deepseek-chat
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=

# exposed ports
HOST_PORT=3000
AI_SERVICE_FORWARD_PORT=5555

EXPERIMENTAL_ENGINE_RUST_VERSION=false
LOCAL_STORAGE=.

# [自定义] 推荐问题开关 — 设为 false 关闭 deploy 后自动生成推荐问题
# 本地大模型推理慢时建议关闭，避免堵塞 LLM 调用队列
ENABLE_RECOMMENDATION_QUESTIONS=true
